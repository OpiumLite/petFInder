-- ==========================================
-- ОБРАБОТКА ПЕТОВ
-- ==========================================

local processedPets = {}

local function ProcessPet(pet, isNew)
    if not pet or not pet.Name then
        return
    end
    
    if not string.match(pet.Name, "^" .. Settings.PetPrefix) then
        return
    end
    
    if processedPets[pet] then
        return
    end
    
    local petInfo = ExtractPetInfo(pet.Name)
    print(string.format("%s: %s (ID: %s)", isNew and "🆕 Новый пет" or "📌 Пет", petInfo.Name, petInfo.ID))
    
    -- Проверяем, разрешен ли пет перед добавлением в processedPets
    if IsPetAllowed(petInfo.Name) then
        processedPets[pet] = true
        pet:SetAttribute("Processed", true)
        SendPetNotification(pet, petInfo, isNew)
    else
        -- Все равно добавляем в processed, чтобы не спамить логами
        processedPets[pet] = true
        pet:SetAttribute("Processed", true)
        print(string.format("⏭️ Пропущен (не в списке): %s", petInfo.Name))
    end
end

-- ==========================================
-- СКАНИРОВАНИЕ
-- ==========================================

local function ScanForPets()
    local container = GetPetContainer()
    if not container then
        return
    end
    
    local found = 0
    local allowedFound = 0
    
    for _, child in ipairs(container:GetChildren()) do
        if string.match(child.Name, "^" .. Settings.PetPrefix) then
            ProcessPet(child, false)
            found = found + 1
        end
    end
    
    if found > 0 then
        print(string.format("📊 Найдено %d петов", found))
        print(string.format("📊 Разрешенные петы: %s", table.concat(Settings.AllowedPets, ", ")))
    end
    
    return found
end

local function ScanForNewPets()
    local container = GetPetContainer()
    if not container then
        return
    end
    
    for _, child in ipairs(container:GetChildren()) do
        if string.match(child.Name, "^" .. Settings.PetPrefix) then
            if not processedPets[child] then
                ProcessPet(child, true)
            end
        end
    end
end

-- ==========================================
-- МОНИТОРИНГ
-- ==========================================

local function StartMonitoring()
    local container = GetPetContainer()
    if not container then
        print("❌ Не удалось запустить мониторинг")
        return
    end
    
    container.ChildAdded:Connect(function(child)
        task.wait(0.5)
        if string.match(child.Name, "^" .. Settings.PetPrefix) then
            ProcessPet(child, true)
        end
    end)
    
    spawn(function()
        while task.wait(Settings.ScanInterval) do
            ScanForNewPets()
        end
    end)
    
    print("✅ Мониторинг запущен!")
    print(string.format("📋 Отслеживаются: %s", table.concat(Settings.AllowedPets, ", ")))
end


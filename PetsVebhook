-- ==========================================
-- ОБРАБОТКА ПЕТОВ
-- ==========================================
local function ProcessPet(pet, isNew)
    return SafeCall(function()
        if not pet or not pet.Name then
            return
        end
        
        if not string.match(pet.Name, "^" .. Settings.PetPrefix) then
            return
        end
        
        if processedPets[pet] then
            return
        end
        
        if isPaused then
            print("⏸️ Трекер на паузе, пропускаем...")
            return
        end
        
        local petInfo = ExtractPetInfo(pet.Name)
        
        if not ShouldTrackPet(petInfo.Name) then
            return
        end
        
        print(string.format("🎯 ЦЕЛЕВОЙ ПЕТ НАЙДЕН! %s", petInfo.Name))
        
        processedPets[pet] = true
        pet:SetAttribute("Processed", true)
        
        SendPetNotification(pet, petInfo, isNew)
    end)
end

-- ==========================================
-- СКАНИРОВАНИЕ
-- ==========================================
local function ScanForPets()
    if isPaused then return end
    
    return SafeCall(function()
        local container = GetPetContainer()
        if not container then
            return
        end
        
        local found = 0
        
        for _, child in ipairs(container:GetChildren()) do
            if string.match(child.Name, "^" .. Settings.PetPrefix) then
                local petInfo = ExtractPetInfo(child.Name)
                if ShouldTrackPet(petInfo.Name) then
                    ProcessPet(child, false)
                    found = found + 1
                end
            end
        end
        
        if found > 0 then
            print(string.format("📊 Найдено %d целевых петов", found))
        end
        
        return found
    end)
end

local function ScanForNewPets()
    if isPaused then return end
    
    return SafeCall(function()
        local container = GetPetContainer()
        if not container then
            return
        end
        
        for _, child in ipairs(container:GetChildren()) do
            if string.match(child.Name, "^" .. Settings.PetPrefix) then
                if not processedPets[child] then
                    local petInfo = ExtractPetInfo(child.Name)
                    if ShouldTrackPet(petInfo.Name) then
                        ProcessPet(child, true)
                    end
                end
            end
        end
    end)
end


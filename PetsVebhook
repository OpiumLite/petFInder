-- ==========================================
-- БЕЗОПАСНОЕ ВЫПОЛНЕНИЕ
-- ==========================================
local function SafeCall(func, ...)
    local success, result = pcall(func, ...)
    if not success then
        errorCount = errorCount + 1
        if errorCount % 10 == 0 then
            print(string.format("⚠️ Поймано %d ошибок (игнорируем)", errorCount))
        end
        return nil
    end
    return result
end


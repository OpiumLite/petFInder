-- ==========================================
-- ОТПРАВКА В DISCORD
-- ==========================================
local function SendToDiscord(message, embedData, pingRare)
    local http = game:GetService("HttpService")
    
    if notificationCount >= Advanced.MaxNotificationsPerSession then
        print("⚠️ Достигнут лимит уведомлений!")
        return false
    end
    
    local currentTime = os.time()
    if currentTime - lastNotificationTime < Advanced.CooldownBetweenNotifications then
        print("⏳ Кулдаун, пропускаем...")
        return false
    end
    
    local payload = {}
    local content = message or ""
    
    if pingRare and Advanced.SendPingOnRare then
        content = "@everyone " .. content
    end
    
    payload.content = content
    
    if embedData then
        payload.embeds = embedData
    end
    
    local jsonData = http:JSONEncode(payload)
    
    local success = false
    
    if request then
        local response = request({
            Url = WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = jsonData
        })
        success = response and (response.StatusCode == 200 or response.StatusCode == 204)
    elseif syn and syn.request then
        local response = syn.request({
            Url = WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = jsonData
        })
        success = response and (response.StatusCode == 200 or response.StatusCode == 204)
    elseif http_request then
        local response = http_request({
            Url = WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = jsonData
        })
        success = response and (response.StatusCode == 200 or response.StatusCode == 204)
    end
    
    if success then
        notificationCount = notificationCount + 1
        lastNotificationTime = currentTime
    end
    
    return success
end

-- ==========================================
-- ИЗВЛЕЧЕНИЕ ИНФОРМАЦИИ О ПЕТЕ
-- ==========================================
local function ExtractPetInfo(modelName)
    local nameMatch = string.match(modelName, "^WildPet_(.-)_WildPet_")
    local idMatch = string.match(modelName, "_WildPet_([%x%-]+)$")
    
    return {
        Name = nameMatch or "Unknown",
        ID = idMatch or "Unknown"
    }
end

-- ==========================================
-- ПОЛУЧЕНИЕ ПОЗИЦИИ ПЕТА
-- ==========================================
local function GetPetPosition(pet)
    local part = pet:FindFirstChild("PrimaryPart")
    if not part then
        part = pet:FindFirstChild("Head")
    end
    if not part then
        part = pet:FindFirstChildWhichIsA("BasePart")
    end
    if not part then
        for _, child in ipairs(pet:GetChildren()) do
            if child:IsA("BasePart") then
                part = child
                break
            end
        end
    end
    return part and part.Position or nil
end

-- ==========================================
-- ПОЛУЧЕНИЕ РАССТОЯНИЯ ДО ПЕТА
-- ==========================================
local function GetDistanceToPet(pet)
    local player = game.Players.LocalPlayer
    local character = player and player.Character
    if not character then return "Unknown" end
    
    local pos = GetPetPosition(pet)
    if not pos then return "Unknown" end
    
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then return "Unknown" end
    
    local distance = (root.Position - pos).Magnitude
    return string.format("%.1f м", distance)
end


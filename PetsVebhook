    isPaused = not isPaused
    print(string.format("⏸️ Трекер %s", isPaused and "приостановлен" : "возобновлен"))
end

getgenv().scan = function()
    print("🔍 Принудительное сканирование...")
    ScanForPets()
end

getgenv().server = function()
    local link, job = GetServerLink()
    print("🆔 Job ID: " .. job)
    print("🔗 Ссылка (TeleportService):")
    print(link)
end

getgenv().reset = function()
    processedPets = {}
    notificationCount = 0
    totalPetsFound = 0
    print("🔄 Сброшены все обработанные петы")
end

getgenv().logs = function()
    if #foundPetsLog == 0 then
        print("📭 Лог пуст")
        return
    end
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    print("📋 ЛОГ НАЙДЕННЫХ ПЕТОВ:")
    for i, entry in ipairs(foundPetsLog) do
        print(string.format("  %d. %s", i, entry:gsub("\n", "")))
    end
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
end

getgenv().clear = function()
    foundPetsLog = {}
    print("🧹 Лог очищен")
end

getgenv().help = function()
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    print("📖 ДОСТУПНЫЕ КОМАНДЫ:")
    print("")
    print("  📊 СТАТУС:")
    print("    status()    - Полная информация о трекере")
    print("    targets()   - Список целевых петов")
    print("    players()   - Количество игроков на сервере")
    print("")
    print("  🎮 УПРАВЛЕНИЕ:")
    print("    pause()     - Пауза/возобновление")
    print("    scan()      - Принудительное сканирование")
    print("    reset()     - Сбросить обработанных петов")
    print("")
    print("  📁 ЛОГИ:")
    print("    logs()      - Показать лог найденных")
    print("    clear()     - Очистить лог")
    print("")
    print("  🔗 СЕРВЕР:")
    print("    server()    - Показать ссылку на сервер")
    print("")
    print("  ❓ ПОМОЩЬ:")
    print("    help()      - Показать это сообщение")
    print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
end


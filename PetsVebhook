    local serverLink, jobId = GetServerLink()
    
    local title = isNew and "🐰 НОВЫЙ PET ПОЯВИЛСЯ!" or "🐰 PET НАЙДЕН!"
    local color = isNew and 0x00FF00 or 0x3498DB
    
    local embed = {{
        title = title,
        color = color,
        fields = {
            {
                name = "Имя пета",
                value = petInfo.Name,
                inline = true
            },
            {
                name = "ID пета",
                value = "`" .. petInfo.ID .. "`",
                inline = true
            },
            {
                name = "Позиция",
                value = posText,
                inline = false
            },
            {
                name = "🔗 Ссылка на сервер (TeleportService)",
                value = "```lua\n" .. serverLink .. "\n```",
                inline = false
            },
            {
                name = "🆔 Job ID",
                value = "`" .. jobId .. "`",
                inline = false
            },
            {
                name = "⏰ Время",
                value = os.date("%H:%M:%S"),
                inline = true
            }
        },
        footer = {
            text = "WildPet Tracker"
        },
        timestamp = os.date("!%Y-%m-%dT%H:%M:%S.000Z")
    }}
    
    local content = string.format(
        "**%s**\n" ..
        "🐰 Имя: **%s**\n" ..
        "🔑 ID: `%s`\n" ..
        "📍 Позиция: %s\n" ..
        "━━━━━━━━━━━━━━━━━━━━━\n" ..
        "🔗 **Ссылка на сервер (TeleportService):**\n```lua\n%s\n```\n" ..
        "🆔 **Job ID:** `%s`\n" ..
        "⏰ Время: %s",
        title,
        petInfo.Name,
        petInfo.ID,
        posText,
        serverLink,
        jobId,
        os.date("%H:%M:%S")
    )
    
    SendToDiscord(content, embed)
    print(string.format("✅ Отправлено: %s (Job ID: %s)", petInfo.Name, jobId))
end

-- ==========================================
-- ОБРАБОТКА ПЕТОВ
-- ==========================================

local processedPets = {}

local function ProcessPet(pet, isNew)
    if not pet or not pet.Name then
        return
    end
    
    if not string.match(pet.Name, "^" .. Settings.PetPrefix) then
        return
    end
    
    if processedPets[pet] then
        return
    end
    
    print(string.format("%s: %s", isNew and "🆕 Новый пет" or "📌 Пет", pet.Name))
    
    local petInfo = ExtractPetInfo(pet.Name)
    print(string.format("📊 Имя: %s, ID: %s", petInfo.Name, petInfo.ID))
    
    processedPets[pet] = true
    pet:SetAttribute("Processed", true)
    
    SendPetNotification(pet, petInfo, isNew)
end

-- ==========================================
-- СКАНИРОВАНИЕ
-- ==========================================

local function ScanForPets()
    local container = GetPetContainer()
    if not container then
        return
    end
    
    local found = 0
    
    for _, child in ipairs(container:GetChildren()) do
        if string.match(child.Name, "^" .. Settings.PetPrefix) then
            ProcessPet(child, false)
            found = found + 1
        end
    end
    
    if found > 0 then
        print(string.format("📊 Найдено %d петов", found))
    end
    
    return found
end

local function ScanForNewPets()
    local container = GetPetContainer()
    if not container then
        return
    end
    
    for _, child in ipairs(container:GetChildren()) do
        if string.match(child.Name, "^" .. Settings.PetPrefix) then
            if not processedPets[child] then
                ProcessPet(child, true)
            end
        end
    end
end

-- ==========================================
-- МОНИТОРИНГ
-- ==========================================

local function StartMonitoring()
    local container = GetPetContainer()
    if not container then
        print("❌ Не удалось запустить мониторинг")
        return
    end
    
    container.ChildAdded:Connect(function(child)
        task.wait(0.5)
        if string.match(child.Name, "^" .. Settings.PetPrefix) then
            ProcessPet(child, true)
        end
    end)
    
    spawn(function()
        while task.wait(Settings.ScanInterval) do
            ScanForNewPets()
        end
    end)
    
    print("✅ Мониторинг запущен!")
end


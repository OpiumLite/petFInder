-- ==========================================
-- МОНИТОРИНГ
-- ==========================================
local function StartMonitoring()
    local container = GetPetContainer()
    if not container then
        print("❌ Не удалось запустить мониторинг")
        return
    end
    
    -- Обновляем количество игроков каждые 10 секунд
    spawn(function()
        while task.wait(10) do
            GetPlayerCount()
            if Advanced.ShowPlayerCountInStatus then
                print(string.format("👥 Игроков на сервере: %d", currentPlayerCount))
            end
        end
    end)
    
    container.ChildAdded:Connect(function(child)
        task.wait(0.5)
        if string.match(child.Name, "^" .. Settings.PetPrefix) then
            local petInfo = ExtractPetInfo(child.Name)
            if ShouldTrackPet(petInfo.Name) then
                ProcessPet(child, true)
            end
        end
    end)
    
    spawn(function()
        while task.wait(Settings.ScanInterval) do
            ScanForNewPets()
        end
    end)
    
    print("✅ Мониторинг запущен!")
end


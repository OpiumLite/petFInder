getgenv().addpet = function(petName)
    if not petName or petName == "" then
        print("❌ Укажите имя пета: addpet('имя')")
        return
    end
    table.insert(Settings.AllowedPets, string.lower(petName))
    print(string.format("✅ Добавлен: %s", petName))
    print(string.format("📋 Сейчас отслеживаются: %s", table.concat(Settings.AllowedPets, ", ")))
end

getgenv().removepet = function(petName)
    if not petName or petName == "" then
        print("❌ Укажите имя пета: removepet('имя')")
        return
    end
    local lowerName = string.lower(petName)
    for i, v in ipairs(Settings.AllowedPets) do
        if string.lower(v) == lowerName then
            table.remove(Settings.AllowedPets, i)
            print(string.format("✅ Удален: %s", petName))
            print(string.format("📋 Сейчас отслеживаются: %s", table.concat(Settings.AllowedPets, ", ")))
            return
        end
    end
    print(string.format("❌ Пет '%s' не найден в списке", petName))
end

